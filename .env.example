# ================================================
# LIFEVERSE - Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# MongoDB Connection String (Required)
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/lifeverse?retryWrites=true&w=majority

# Authentication Secret (Required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-super-secret-key-at-least-32-chars-long

# App URLs
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Secret (Optional, falls back to BETTER_AUTH_SECRET)
JWT_SECRET=another-secret-for-jwt-tokens

# Email (Optional - for password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
